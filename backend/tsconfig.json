{
  "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "resolveJsonModule": true,
      "declaration": true,
      "sourceMap": true,
      "types": ["vitest/globals","node"],
      "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist",  "src/__tests__", "tests"]
}