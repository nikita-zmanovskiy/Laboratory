PORT=3000
NODE_ENV=development
HTTPS=false
JSON_LIMIT=10mb
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
CORS_METHODS=GET,POST,DELETE
CORS_ALLOWED_HEADERS=Content-Type,x-csrf-token,x-classroom-code
CSP_ENABLED=false

DATABASE_URL=postgresql://ai_lab_user:admin@localhost:5432/ai_lab
PGSSL=false
# Не используй prisma+postgres:// здесь — Nest работает через прямой postgresql://

GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_client_secret
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1

AI_MOCK=false

WS_PORT=3000

# Redis только для нескольких инстансов. Для локалки можно не задавать.
# REDIS_URL=redis://localhost:6379
REDIS_WS_CHANNEL=lab:ws:broadcast
INSTANCE_ID=backend-1

CSRF_SECRET=change_me_to_random_string


LOG_LEVEL=info
# LOG_FILE=logs/app.log
