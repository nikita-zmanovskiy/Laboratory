# Скопируйте в .env.docker и подставьте свои значения:
#   copy .env.docker.example .env.docker
#
# Файл .env.docker в git не попадает (секреты).

# --- GigaChat (обязательно для реальных ответов) ---
GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_client_secret
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1

# false = реальный GigaChat, true = заглушки без сети
AI_MOCK=false

# --- Безопасность ---
CSRF_SECRET=замените_на_длинную_случайную_строку_64_символа

# --- CORS (браузер: фронт на :3001, API через nginx :80) ---
CORS_ORIGINS=http://localhost:3001,http://localhost,http://127.0.0.1:3001
CORS_METHODS=GET,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,x-csrf-token,x-classroom-code,x-teacher-token
CORS_CREDENTIALS=true

CSP_ENABLED=false
HTTPS=false
LOG_LEVEL=info

# --- Redis / WebSocket между инстансами (в compose уже задан REDIS_URL) ---
REDIS_WS_CHANNEL=lab:ws:broadcast
