COMPOSE_PROJECT_NAME=laboratory

HTTP_PORT=80
PUBLIC_APP_URL=http://localhost

POSTGRES_DB=ai_lab
POSTGRES_USER=ai_lab_user
POSTGRES_PASSWORD=admin #или другой пароль, если делали по инструкции, то изменять не надо 

NODE_ENV=production
PORT=3000
HTTPS=false
JSON_LIMIT=10mb

PGSSL=false

CORS_ORIGINS=http://localhost
CORS_METHODS=GET,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,x-csrf-token,x-classroom-code,x-teacher-token
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

CSP_ENABLED=true
CSP_UPGRADE_INSECURE_REQUESTS=false

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_URL=http://localhost
NEXT_PUBLIC_WS_URL=ws://localhost
BACKEND_URL=http://backend:3000

GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_base64_authorization_key
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1

AI_MOCK=false

CSRF_SECRET=change_me_long_random_secret_at_least_64_chars
LOG_LEVEL=info

REDIS_WS_CHANNEL=lab:ws:broadcast