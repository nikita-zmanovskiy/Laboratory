{
	"tabWidth": 3,
	"useTabs": true,
	"semi": true,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"trailingComma": "all",
	"arrowParens": "always",
	"bracketSpacing": true,
	"endOfLine": "lf",
	"printWidth": 50,
	"singleAttributePerLine": true,
	"plugins": ["prettier-plugin-tailwindcss"],
	"tailwindAttributes": ["className"]
}
