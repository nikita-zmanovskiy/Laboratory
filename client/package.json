{
	"name": "laboratory-client",
	"version": "1.0.0",
	"description": "AI Laboratory",
	"author": "Laboratory Team",
	"license": "MIT",
	"keywords": [
		"ai-lab",
		"fsd",
		"nextjs",
		"typescript"
	],
	"private": true,
	"packageManager": "npm@11.6.2",
	"scripts": {
		"devhttps": "next dev -H 0.0.0.0 --experimental-https",
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"check": "npm run lint && npm run typecheck && npm run build",
		"lint:imports": "eslint . --config eslint.sort-imports.config.mjs --fix",
		"prettier": "prettier --write .",
		"prepare": "husky .husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,css,scss}": [
			"prettier --write",
			"eslint . --config eslint.sort-imports.config.mjs --fix"
		]
	},
	"dependencies": {
		"axios": "^1.13.2",
		"next": "^15.3.6",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-markdown": "^10.1.0",
		"recharts": "^3.8.1",
		"zustand": "^5.0.6"

		
	},
	"devDependencies": {
		"@conarti/eslint-plugin-feature-sliced": "^1.0.5",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4.1.11",
		"@types/node": "^20",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"@typescript-eslint/parser": "^8.57.0",
		"eslint": "^9",
		"eslint-config-next": "15.3.6",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.1.11",
		"tw-animate-css": "^1.3.5",
		"typescript": "^5"
	}
}
